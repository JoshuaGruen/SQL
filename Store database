This is a store database. All of the queries display information about items and price.

SELECT item_name,price
FROM superstore
ORDER BY price
;

SELECT item_name,SUM(price)
FROM superstore
;

SELECT category, SUM(price)
FROM superstore
ORDER BY item_name ='Kitchen Supplies'
;

SELECT category, MIN(price)
FROM superstore 
ORDER BY item_name, price
; 
SELECT hotels.hotel_id
FROM vips
JOIN hotels
LIMIT 5
;

SELECT events.event_id,hotels.hotel_name
FROM events
JOIN hotels
ON events.event_id=hotels.hotel_id
;

SELECT member_id
FROM reservations
LIMIT 5
;

SELECT vips.member_id,hotels.hotel_id
FROM vips
JOIN hotels
ON vips.member_since
LIMIT 5
;

SELECT reservations.hotel
FROM reservations
;

SELECT *
FROM hotels
;

