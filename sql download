SELECT COUNT(distinct orderid)
FROM BIT_DB.JanSales
WHERE length(orderid) = 6
AND orderid <> 'Order ID';

SELECT COUNT(distinct orderid)
FROM BIT_DB.JanSales
WHERE Product='iPhone'
AND length(orderid) = 6
AND orderid <> 'Order ID';

SELECT distinct acctnum
FROM BIT_DB.customers cust

INNER JOIN BIT_DB.FebSales Feb
ON cust.order_id=FEB.orderid
WHERE length(orderid) = 6
AND orderid <> 'Order ID';

SELECT distinct Product, price
FROM BIT_DB.JanSales
WHERE price in (SELECT min(price) FROM BIT_DB.JanSales);

SELECT sum(quantity)*price as revenue
,product
FROM BIT_DB.JanSales
GROUP BY product;


SELECT
sum(Quantity),
product,
sum(quantity)*price as revenue
FROM BIT_DB.FebSales
WHERE location = '548 Lincoln St, Seattle, WA 98101'
GROUP BY product;

SELECT 
count(distinct cust.acctnum),
avg(quantity*price)
FROM BIT_DB.FebSales Feb
LEFT JOIN BIT_DB.customers cust
ON FEB.orderid=cust.order_id
WHERE Feb.Quantity>2
AND length(orderid)=6
AND orderid<>'OrderID'
;


--Finds sales that happened in February
SELECT location
FROM BIT_DB.FebSales
WHERE orderdate='02/18/19 01:35'
;

--Sum of orders 
SELECT sum(quantity)
FROM BIT_DB.FebSales
WHERE orderdate like '02/18/19%'
;

--Finds orders in February between 13th and 18th
SELECT orderdate
From BIT_DB.FebSales
WHERE orderdate between '02/13/19 00:00' AND '02/18/19 00:00'
;

--Order id that includes 16 and 0
SELECT orderID
FROM BIT_DB.MarSales
WHERE orderID LIKE '16_0%'
;

--Orders that include symbols
SELECT orderdate
FROM BIT_DB.MarSales
WHERE orderdate LIKE '%!_%'
ESCAPE '!'
;

--Shows how many products were sold
SELECT sum (Product)
FROM BIT_DB.FebSales
WHERE Product LIKE '%headphones%'
GROUP BY Product
;

--Shows the average price of products
SELECT sum (Quantity*price)/count(cust.acctnum)
FROM BIT_DB.FebSales feb
LEFT JOIN BIT_DB.customers cust
ON Feb.orderid=cust.order_id
;

--Average orders
SELECT orderID
FROM BIT_DB.AprSales
WHERE orderdate LIKE '04/1%'
AND location LIKE '%GA'
GROUP BY orderID
HAVING AVG (price) > 1000
;

--Sales that had same order
SELECT location,orderID
FROM BIT_DB.MaySales
WHERE orderID LIKE '1943_5'
ORDER BY orderID
;

--The produce revenue 
SELECT product,sum(Quantity*Price)
FROM BIT_DB.JanSales
GROUP BY product
ORDER BY sum(Quantity*Price) desc
LIMIT 1
;
